{
    "fields": {
        "name": {
            "type": "varchar",
            "maxLength": 100
        },
        "purchaseOrder": {
            "type": "link",
            "entity": "InventoryPurchaseOrder",
            "required": true
        },
        "product": {
            "type": "link",
            "entity": "InventoryProduct",
            "required": true
        },
        "qtyOrdered": {
            "type": "int",
            "required": true,
            "default": 0
        },
        "qtyReceived": {
            "type": "int",
            "default": 0
        },
        "unitCost": {
            "type": "currency"
        },
        "ccInventoryId": {
            "type": "int",
            "readOnly": true
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true,
            "fieldManagerParamList": ["useNumericFormat"]
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true,
            "fieldManagerParamList": ["useNumericFormat"]
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "entity": "User"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "entity": "User"
        }
    },
    "links": {
        "purchaseOrder": {
            "type": "belongsTo",
            "entity": "InventoryPurchaseOrder",
            "foreign": "purchaseOrderItems"
        },
        "product": {
            "type": "belongsTo",
            "entity": "InventoryProduct",
            "foreign": "purchaseOrderItems"
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "ccInventoryId": {
            "columns": ["ccInventoryId"]
        }
    }
}
